{
  "name": "revenue-clarity",
  "version": "0.1.0",
  "description": "Simplify complex business revenue metrics — calculate, understand, and present your financials with clarity.",
  "author": "Your Name <you@email.com>",
  "license": "MIT",
  "private": false,
  "type": "module",

  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && cp src/dashboard.html dist/index.html",
    "build:static": "mkdir -p dist && cp src/dashboard.html dist/index.html",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },

  "dependencies": {
    "chart.js": "^4.4.0",
    "date-fns": "^3.0.0",
    "decimal.js": "^10.4.3",
    "jspdf": "^2.5.1",
    "xlsx": "^0.18.5",
    "zod": "^3.22.0"
  },

  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0"
  },

  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },

  "keywords": [
    "revenue",
    "finance",
    "business-metrics",
    "calculator",
    "mrr",
    "ltv",
    "cac",
    "saas",
    "dashboard",
    "typescript"
  ],

  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/revenue-clarity.git"
  },

  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/revenue-clarity/issues"
  },

  "homepage": "https://github.com/YOUR_USERNAME/revenue-clarity#readme"
}
